--// SAFE CONNECTION FUNCTION
local function SafeConnect(button, callback)
    if not button then
        warn("Button is nil, cannot connect")
        return
    end
    
    local success, err = pcall(function()
        button.MouseButton1Click:Connect(callback)
    end)
    
    if not success then
        warn("Failed to connect button " .. button.Name .. ": " .. tostring(err))
    end
end

