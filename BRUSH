--// BL Function (Build Terrain)
local function BL(d)
    local pos = Vector3.new(d[1], d[2], d[3])
    local sx, sy, sz = d[4], d[5], d[6]
    local matName = d[7]
    local shape = d[8] or "Ball"
    local grassIdx = d[9] or currentGrassColorIndex
    local leafyIdx = d[10] or currentLeafyGrassColorIndex
    local groundIdx = d[11] or currentGroundColorIndex
    
    pcall(function() Terrain:SetMaterialColor(Enum.Material.Grass, grassColors[grassIdx].color) end)
    pcall(function() Terrain:SetMaterialColor(Enum.Material.LeafyGrass, leafyGrassColors[leafyIdx].color) end)
    pcall(function() Terrain:SetMaterialColor(Enum.Material.Ground, groundColors[groundIdx].color) end)
    
    if matName == "SmoothBrush" then
        local radius = sx
        for x = -radius, radius, 4 do
            for y = -radius, radius, 4 do
                for z = -radius, radius, 4 do
                    local checkPos = pos + Vector3.new(x, y, z)
                    local dist = (Vector3.new(x, y, z)).Magnitude
                    if dist <= radius then
                        local smoothFactor = 1 - (dist / radius)
                        if smoothFactor > 0.3 then
                            Terrain:FillBall(checkPos, 3.2, Enum.Material.Grass)
                        end
                    end
                end
            end
        end
        return d
    end
    
    local mat = Enum.Material.Grass
    for _, m in ipairs(Materials) do
        if m.Name == matName then mat = m.Mat break end
    end
    
    if shape == "Block" then
        local sizeVec = Vector3.new(sx, sy, sz)
        Terrain:FillBlock(CFrame.new(pos), sizeVec, mat)
    else
        Terrain:FillBall(pos, math.max(sx, sy, sz)/2, mat)
    end
    
    return d
end

--// Spawn Terrain
local function SpawnTerrain()
    if not PreviewPos then return false end
    local data = {
        math.floor(PreviewPos.X),
        math.floor(PreviewPos.Y),
        math.floor(PreviewPos.Z),
        SizeX, SizeY, SizeZ,
        CurrentMaterial.Name,
        CurrentShape,
        currentGrassColorIndex,
        currentLeafyGrassColorIndex,
        currentGroundColorIndex
    }
    BL(data)
    table.insert(UndoHistory, data)
    RedoHistory = {}
    table.insert(SpawnedData, data)
    return true
end

--// UNDO
local function Undo()
    if #UndoHistory == 0 then return false, "Nothing to undo" end
    local lastData = table.remove(UndoHistory)
    table.insert(RedoHistory, lastData)
    for i = #SpawnedData, 1, -1 do
        local d = SpawnedData[i]
        if d[1] == lastData[1] and d[2] == lastData[2] and d[3] == lastData[3] then
            table.remove(SpawnedData, i)
            break
        end
    end
    Terrain:Clear()
    for _, d in ipairs(SpawnedData) do BL(d) end
    return true, "Undone 1 terrain"
end

--// REDO
local function Redo()
    if #RedoHistory == 0 then return false, "Nothing to redo" end
    local data = table.remove(RedoHistory)
    table.insert(UndoHistory, data)
    table.insert(SpawnedData, data)
    BL(data)
    return true, "Redone 1 terrain"
end

