        part.CastShadow = false
        part.Parent = Workspace
        table.insert(BrushSmoothParts, part)
    end
end

--// Update Brush Smooth Preview
local function UpdateBrushSmoothPreview(position, normal)
    if not BrushSmoothPreview or not position then return end
    
    local lookVector = normal
    local rightVector = Vector3.new(1, 0, 0)
    if math.abs(normal.X) > 0.9 then
        rightVector = Vector3.new(0, 1, 0)
    end
    local upVector = lookVector:Cross(rightVector).Unit
    rightVector = upVector:Cross(lookVector).Unit
    
    BrushSmoothPreview.CFrame = CFrame.fromMatrix(position, rightVector, upVector)
    BrushSmoothPreview.Size = Vector3.new(0.3, BrushSmoothRadius * 2, BrushSmoothRadius * 2)
    
    for i, part in ipairs(BrushSmoothParts) do
        local angle = (i / 8) * math.pi * 2 + (tick() * 2)
        local offset = Vector3.new(
            math.cos(angle) * BrushSmoothRadius * 0.7,
            math.sin(angle) * BrushSmoothRadius * 0.3,
            0
        )
        local rotatedOffset = rightVector * offset.X + upVector * offset.Y + lookVector * 0.5
        part.Position = position + rotatedOffset
        local pulse = 1 + math.sin(tick() * 3 + i) * 0.3
        part.Size = Vector3.new(pulse, pulse, pulse)
    end
end

--// Apply Smooth Brush Effect - SIMPLIFIED & FIXED
local function ApplyBrushSmooth(position, normal)
    if not position then return end
    
    -- Simple terrain modification using FillBall
    local success, err = pcall(function()
        -- Create terrain at brush position with current material
        local mat = CurrentMaterial.Mat
        
        -- Fill a ball at the brush position
        local fillRadius = BrushSmoothRadius * 0.5
        Terrain:FillBall(position, fillRadius, mat)
        
        -- Also fill around it for smoothing effect
        for i = 1, 5 do
            local offset = Vector3.new(
                math.random(-fillRadius, fillRadius),
                math.random(-fillRadius, fillRadius),
                math.random(-fillRadius, fillRadius)
            )
            if offset.Magnitude <= fillRadius then
                Terrain:FillBall(position + offset, fillRadius * 0.5, mat)
            end
        end
    end)
    
    if not success then
        warn("Brush Error: " .. tostring(err))
    end
end

--// Update Preview Loop
local function UpdatePreview()
    if not PreviewPart then CreatePreview() end
    
    local result = GetRaycast()
    if result then
        PreviewPos = result.Position
        
        if BrushSmoothEnabled then
            -- Hide normal preview, show brush preview
            PreviewPart.Transparency = 1
            if not BrushSmoothPreview then CreateBrushSmoothPreview() end
            UpdateBrushSmoothPreview(result.Position, result.Normal)
            
            -- Apply brush effect if active (mouse held down)
            if BrushActive then
                ApplyBrushSmooth(result.Position, result.Normal)
            end
        else
            -- Normal mode
            PreviewPart.Transparency = 0.65
            if BrushSmoothPreview then
                BrushSmoothPreview.Transparency = 1
                for _, part in ipairs(BrushSmoothParts) do
                    part.Transparency = 1
                end
            end
            
            if CurrentShape == "Ball" then
                PreviewPart.Shape = Enum.PartType.Ball
                PreviewPart.Size = Vector3.new(SizeX, SizeY, SizeZ)
            else
                PreviewPart.Shape = Enum.PartType.Block
                PreviewPart.Size = Vector3.new(SizeX, SizeY, SizeZ)
            end
            PreviewPart.Position = PreviewPos
        end
    else
        -- No raycast hit
        PreviewPart.Transparency = 0.7
        if BrushSmoothPreview then
            BrushSmoothPreview.Transparency = 1
            for _, part in ipairs(BrushSmoothParts) do
                part.Transparency = 1
            end
        end
    end
end

