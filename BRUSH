--// Raycast
local function GetRaycast()
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local ray = Camera:ViewportPointToRay(center.X, center.Y)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    local filterList = {}
    if PreviewPart then table.insert(filterList, PreviewPart) end
    if BrushSmoothPreview then table.insert(filterList, BrushSmoothPreview) end
    for _, part in ipairs(BrushSmoothParts) do
        table.insert(filterList, part)
    end
    if #filterList > 0 then
        params.FilterDescendantsInstances = filterList
    end
    return Workspace:Raycast(ray.Origin, ray.Direction * 1000, params)
end

