--// Create Brush Smooth Preview
local function CreateBrushSmoothPreview()
    if BrushSmoothPreview then BrushSmoothPreview:Destroy() end
    for _, part in ipairs(BrushSmoothParts) do
        part:Destroy()
    end
    BrushSmoothParts = {}
    
    BrushSmoothPreview = Instance.new("Part")
    BrushSmoothPreview.Shape = Enum.PartType.Cylinder
    BrushSmoothPreview.Material = Enum.Material.Neon
    BrushSmoothPreview.Color = Color3.fromRGB(0, 255, 200)
    BrushSmoothPreview.Transparency = 0.6
    BrushSmoothPreview.CanCollide = false
    BrushSmoothPreview.Anchored = true
    BrushSmoothPreview.CastShadow = false
    BrushSmoothPreview.Size = Vector3.new(0.5, BrushSmoothRadius * 2, BrushSmoothRadius * 2)
    BrushSmoothPreview.CFrame = CFrame.new(0, 0, 0) * CFrame.Angles(0, 0, math.rad(90))
