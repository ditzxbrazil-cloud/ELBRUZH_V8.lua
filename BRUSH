        BrushActive = false
    end
end)

-- Drag Panel
local drag = false
local startPos, startFrame

local function StartDrag(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        drag = true
        startPos = input.Position
        startFrame = panel.Position
    end
end

local function EndDrag()
    drag = false
end

local function UpdateDrag(input)
    if drag and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - startPos
        panel.Position = UDim2.new(startFrame.X.Scale, startFrame.X.Offset + delta.X, startFrame.Y.Scale, startFrame.Y.Offset + delta.Y)
    end
end

if titleBar then
    titleBar.InputBegan:Connect(StartDrag)
    titleBar.InputEnded:Connect(EndDrag)
end
UserInputService.InputChanged:Connect(UpdateDrag)

