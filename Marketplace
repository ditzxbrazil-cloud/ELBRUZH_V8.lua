    self:EnableDragging(self.MinimizedIcon)
    
    --// Open Category
    self.OpenCategoryBtn.MouseButton1Click:Connect(function()
        if self.CategoryWindow.Visible then
            self:CloseCategoryWindow()
        else
            self:OpenCategoryWindow()
        end
    end)
    
    --// Close Category
    self.CloseCatBtn.MouseButton1Click:Connect(function()
        self:CloseCategoryWindow()
    end)
    
    --// Open Original Clothes
    self.OriginalClothesBtn.MouseButton1Click:Connect(function()
        if self.OriginalWindow.Visible then
            self:CloseOriginalWindow()
        else
            self:OpenOriginalWindow()
        end
    end)
    
    --// Close Original
    self.CloseOriginalBtn.MouseButton1Click:Connect(function()
        self:CloseOriginalWindow()
    end)
    
    --// View
    self.ViewBtn.MouseButton1Click:Connect(function()
        self:ViewItem(self.IDInput.Text)
    end)
    
    self.IDInput.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            self:ViewItem(self.IDInput.Text)
        end
    end)
    
    --// Equip/Unequip
    self.EquipBtn.MouseButton1Click:Connect(function()
        self:EquipItem()
    end)
    
    self.UnequipBtn.MouseButton1Click:Connect(function()
        self:UnequipItem()
    end)
    
    --// Minimize/Restore
    self.MinimizeBtn.MouseButton1Click:Connect(function()
        self:MinimizeMain()
    end)
    
    self.MinimizedIcon.MouseButton1Click:Connect(function()
        self:RestoreMain()
    end)
    
    --// Close
    self.CloseBtn.MouseButton1Click:Connect(function()
        self.ScreenGui:Destroy()
    end)
    
    --// Hover effects
    self.OpenCategoryBtn.MouseEnter:Connect(function()
        TweenService:Create(self.OpenCategoryBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 180, 255)}):Play()
    end)
    self.OpenCategoryBtn.MouseLeave:Connect(function()
        TweenService:Create(self.OpenCategoryBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 150, 255)}):Play()
    end)
    
    self.OriginalClothesBtn.MouseEnter:Connect(function()
        TweenService:Create(self.OriginalClothesBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255, 180, 0)}):Play()
    end)
    self.OriginalClothesBtn.MouseLeave:Connect(function()
        TweenService:Create(self.OriginalClothesBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255, 150, 0)}):Play()
    end)
    
    self.ViewBtn.MouseEnter:Connect(function()
        TweenService:Create(self.ViewBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(120, 120, 255)}):Play()
    end)
    self.ViewBtn.MouseLeave:Connect(function()
        TweenService:Create(self.ViewBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(100, 100, 255)}):Play()
    end)
    
    self.EquipBtn.MouseEnter:Connect(function()
        if not self.IsItemEquipped then
            TweenService:Create(self.EquipBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 230, 115)}):Play()
        end
    end)
    self.EquipBtn.MouseLeave:Connect(function()
        if not self.IsItemEquipped then
            TweenService:Create(self.EquipBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 200, 100)}):Play()
        end
    end)
    
    self.UnequipBtn.MouseEnter:Connect(function()
        TweenService:Create(self.UnequipBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255, 100, 100)}):Play()
    end)
    self.UnequipBtn.MouseLeave:Connect(function()
        TweenService:Create(self.UnequipBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255, 70, 70)}):Play()
    end)
    
    --// Initial scan
    wait(1)
    self:ScanOriginalClothes()
