end

function shhhhnayy05:GetThumbnail(assetId)
    return string.format("https://www.roblox.com/asset-thumbnail/image?assetId=%d&width=150&height=150&format=png", assetId)
end

function shhhhnayy05:GetAssetInfo(assetId)
    local success, info = pcall(function()
        return MarketplaceService:GetProductInfo(tonumber(assetId))
    end)
    if success then
        return info
    else
        return nil
    end
end

function shhhhnayy05:ViewItem(assetId)
    if not assetId or assetId == "" then
        self.ItemName.Text = "❌ Masukkan ID!"
        self.ItemName.TextColor3 = Color3.fromRGB(255, 100, 100)
        delay(2, function()
            self.ItemName.Text = "No item selected"
            self.ItemName.TextColor3 = Color3.fromRGB(255, 255, 255)
        end)
        return
    end
    
    local numId = tonumber(assetId)
    if not numId then
        self.ItemName.Text = "❌ ID harus angka!"
        self.ItemName.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end
    
    self.LoadingText.Visible = true
    self.PreviewImage.Image = ""
    self.ItemStatus.Text = "Status: Loading..."
    self.ItemStatus.TextColor3 = Color3.fromRGB(100, 200, 255)
    
    local info = nil
    local success, err = pcall(function()
        info = self:GetAssetInfo(assetId)
    end)
    
    if success and info and info.Name then
        self.CurrentItem = {
            id = numId,
            name = info.Name,
            type = info.AssetTypeId,
            creator = info.Creator and info.Creator.Name or "Unknown",
            category = self.CurrentCategory
        }
        
        self.PreviewImage.Image = self:GetThumbnail(numId)
        self.ItemName.Text = info.Name
        self.ItemName.TextColor3 = Color3.fromRGB(255, 255, 255)
        self.ItemType.Text = "Kategori: " .. self.CurrentCategory
        
        self:CheckEquippedStatus()
    else
        self.ItemName.Text = "❌ Item tidak ditemukan!"
        self.ItemName.TextColor3 = Color3.fromRGB(255, 100, 100)
        self.ItemType.Text = "Kategori: " .. self.CurrentCategory
        self.ItemStatus.Text = "Status: Error - Invalid ID"
        self.ItemStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
        self.CurrentItem = nil
    end
    
    self.LoadingText.Visible = false
end

function shhhhnayy05:CheckEquippedStatus()
    if not self.CurrentItem then 
        self.ItemStatus.Text = "Status: Ready"
        self.ItemStatus.TextColor3 = Color3.fromRGB(100, 255, 150)
        return 
    end
    
    local category = self.CurrentCategory
    local id = self.CurrentItem.id
    local isEquipped = false
    
    if category == "ClassicShirts" and self.EquippedItems.ClassicShirts then
        isEquipped = self.EquippedItems.ClassicShirts.id == id
    elseif category == "ClassicPants" and self.EquippedItems.ClassicPants then
        isEquipped = self.EquippedItems.ClassicPants.id == id
    elseif category == "TShirts" and self.EquippedItems.TShirts then
        isEquipped = self.EquippedItems.TShirts.id == id
    elseif category == "Hair" and self.EquippedItems.Hair then
        isEquipped = self.EquippedItems.Hair.id == id
    elseif category == "Faces" and self.EquippedItems.Faces then
        isEquipped = self.EquippedItems.Faces.id == id
    elseif category == "Heads" and self.EquippedItems.Heads then
        isEquipped = self.EquippedItems.Heads.id == id
    elseif category == "Hats" then
        for _, item in ipairs(self.EquippedItems.Hats) do
            if item.id == id then isEquipped = true break end
        end
    elseif category == "Animations" and self.EquippedItems.Animations then
        isEquipped = self.EquippedItems.Animations.id == id
    end
    
    self.IsItemEquipped = isEquipped
    
    if isEquipped then
        self.ItemStatus.Text = "Status: ✅ Sudah dipakai"
        self.ItemStatus.TextColor3 = Color3.fromRGB(100, 255, 100)
        self.EquipBtn.Text = "✅ SUDAH DIPAKAI"
        self.EquipBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    else
        self.ItemStatus.Text = "Status: ❌ Belum dipakai"
        self.ItemStatus.TextColor3 = Color3.fromRGB(255, 200, 100)
        self.EquipBtn.Text = "✅ GUNAKAN"
        self.EquipBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
    end
end

function shhhhnayy05:EquipItem()
    if not self.CurrentItem then
        self.ItemStatus.Text = "Status: ❌ View item dulu!"
        self.ItemStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end
    
    if self.IsItemEquipped then
        self.ItemStatus.Text = "Status: ⚠️ Sudah dipakai!"
        return
    end
    
    local assetId = self.CurrentItem.id
    local category = self.CurrentCategory
    
    local char = LocalPlayer.Character
    if not char then 
        self.ItemStatus.Text = "Status: ❌ Character tidak ada!"
        return 
    end
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then 
        self.ItemStatus.Text = "Status: ❌ Humanoid tidak ada!"
        return 
    end
    
    local desc = humanoid:GetAppliedDescription()
    if not desc then
        desc = Instance.new("HumanoidDescription")
    end
    
    local success, err = pcall(function()
        if category == "ClassicShirts" then
            desc.Shirt = assetId
            self.EquippedItems.ClassicShirts = self.CurrentItem
        elseif category == "ClassicPants" then
            desc.Pants = assetId
            self.EquippedItems.ClassicPants = self.CurrentItem
        elseif category == "TShirts" then
            desc.GraphicTShirt = assetId
            self.EquippedItems.TShirts = self.CurrentItem
        elseif category == "Hair" then
            desc.HairAccessory = assetId
            self.EquippedItems.Hair = self.CurrentItem
        elseif category == "Faces" then
            desc.Face = assetId
            self.EquippedItems.Faces = self.CurrentItem
        elseif category == "Heads" then
            desc.Head = assetId
            self.EquippedItems.Heads = self.CurrentItem
        elseif category == "Hats" then
            table.insert(self.EquippedItems.Hats, self.CurrentItem)
            local current = desc:GetAccessories(true)
            table.insert(current, assetId)
            desc:SetAccessories(current, true)
        elseif category == "Gear" then
            table.insert(self.EquippedItems.Gear, self.CurrentItem)
            spawn(function()
                local success, tool = pcall(function()
                    return InsertService:LoadAsset(assetId):GetChildren()[1]
                end)
                if success and tool and tool:IsA("Tool") then
                    tool.Parent = LocalPlayer.Backpack
                end
            end)
        elseif category == "Animations" then
            desc.IdleAnimation = assetId
            self.EquippedItems.Animations = self.CurrentItem
        end
        
        humanoid:ApplyDescription(desc)
    end)
    
    if success then
        self.IsItemEquipped = true
        self.ItemStatus.Text = "Status: ✅ Berhasil dipakai!"
        self.ItemStatus.TextColor3 = Color3.fromRGB(100, 255, 100)
        self.EquipBtn.Text = "✅ SUDAH DIPAKAI"
        self.EquipBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
        self:UpdateEquippedCount()
    else
        self.ItemStatus.Text = "Status: ❌ Error!"
        self.ItemStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
end

function shhhhnayy05:UnequipItem()
    if not self.CurrentItem then
        self.ItemStatus.Text = "Status: ❌ Tidak ada item!"
        return
    end
    
    if not self.IsItemEquipped then
        self.ItemStatus.Text = "Status: ⚠️ Belum dipakai!"
        return
    end
    
    local assetId = self.CurrentItem.id
    local category = self.CurrentCategory
    
    local char = LocalPlayer.Character
    if not char then return end
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local desc = humanoid:GetAppliedDescription()
    if not desc then
        desc = Instance.new("HumanoidDescription")
    end
    
    local success = pcall(function()
        if category == "ClassicShirts" then
            desc.Shirt = 0
            self.EquippedItems.ClassicShirts = nil
        elseif category == "ClassicPants" then
            desc.Pants = 0
            self.EquippedItems.ClassicPants = nil
        elseif category == "TShirts" then
            desc.GraphicTShirt = 0
            self.EquippedItems.TShirts = nil
        elseif category == "Hair" then
            desc.HairAccessory = 0
            self.EquippedItems.Hair = nil
        elseif category == "Faces" then
            desc.Face = 0
            self.EquippedItems.Faces = nil
        elseif category == "Heads" then
            desc.Head = 0
            self.EquippedItems.Heads = nil
        elseif category == "Hats" then
            for i, item in ipairs(self.EquippedItems.Hats) do
                if item.id == assetId then
                    table.remove(self.EquippedItems.Hats, i)
                    break
                end
            end
        elseif category == "Animations" then
            desc.IdleAnimation = 0
            self.EquippedItems.Animations = nil
        end
        
        local allAcc = {}
        for _, item in ipairs(self.EquippedItems.Hats) do
            table.insert(allAcc, item.id)
        end
        desc:SetAccessories(allAcc, true)
        
        humanoid:ApplyDescription(desc)
    end)
    
    if success then
        self.IsItemEquipped = false
        self.ItemStatus.Text = "Status: ❌ Berhasil dilepas!"
        self.ItemStatus.TextColor3 = Color3.fromRGB(255, 200, 100)
        self.EquipBtn.Text = "✅ GUNAKAN"
        self.EquipBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
        self:UpdateEquippedCount()
    end
end

function shhhhnayy05:UpdateEquippedCount()
    local count = 0
    
    if self.EquippedItems.ClassicShirts then count = count + 1 end
    if self.EquippedItems.ClassicPants then count = count + 1 end
    if self.EquippedItems.TShirts then count = count + 1 end
    if self.EquippedItems.Hair then count = count + 1 end
    if self.EquippedItems.Faces then count = count + 1 end
    if self.EquippedItems.Heads then count = count + 1 end
    if self.EquippedItems.Animations then count = count + 1 end
    
    count = count + #self.EquippedItems.Hats
    count = count + #self.EquippedItems.Gear
    
    self.EquippedText.Text = "🎽 Sedang Dipakai: " .. count .. " items"
end

function shhhhnayy05:MinimizeMain()
