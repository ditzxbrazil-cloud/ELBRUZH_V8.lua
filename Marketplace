function shhhhnayy05:ScanOriginalClothes()
    local char = LocalPlayer.Character
    if not char then return end
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local desc = humanoid:GetAppliedDescription()
    if not desc then return end
    
    self.OriginalClothes = {
        ClassicShirts = nil,
        ClassicPants = nil,
        TShirts = nil,
        Hats = {},
        Hair = nil,
        Faces = nil,
        Heads = nil
    }
    
    if desc.Shirt and desc.Shirt > 0 then
        self.OriginalClothes.ClassicShirts = {id = desc.Shirt, name = "Original Shirt", category = "ClassicShirts"}
    end
    
    if desc.Pants and desc.Pants > 0 then
        self.OriginalClothes.ClassicPants = {id = desc.Pants, name = "Original Pants", category = "ClassicPants"}
    end
    
    if desc.GraphicTShirt and desc.GraphicTShirt > 0 then
        self.OriginalClothes.TShirts = {id = desc.GraphicTShirt, name = "Original T-Shirt", category = "TShirts"}
    end
    
    if desc.HairAccessory and desc.HairAccessory > 0 then
        self.OriginalClothes.Hair = {id = desc.HairAccessory, name = "Original Hair", category = "Hair"}
    end
    
    if desc.Face and desc.Face > 0 then
        self.OriginalClothes.Faces = {id = desc.Face, name = "Original Face", category = "Faces"}
    end
    
    if desc.Head and desc.Head > 0 then
        self.OriginalClothes.Heads = {id = desc.Head, name = "Original Head", category = "Heads"}
    end
    
    local accessories = desc:GetAccessories(true)
    for _, accId in ipairs(accessories) do
        if accId > 0 then
            table.insert(self.OriginalClothes.Hats, {id = accId, name = "Original Accessory", category = "Hats"})
        end
    end
    
    self:UpdateOriginalStatus()
    self:PopulateOriginalList()
end

function shhhhnayy05:UpdateOriginalStatus()
    local count = 0
    if self.OriginalClothes.ClassicShirts then count = count + 1 end
    if self.OriginalClothes.ClassicPants then count = count + 1 end
    if self.OriginalClothes.TShirts then count = count + 1 end
    if self.OriginalClothes.Hair then count = count + 1 end
    if self.OriginalClothes.Faces then count = count + 1 end
    if self.OriginalClothes.Heads then count = count + 1 end
    count = count + #self.OriginalClothes.Hats
    
    self.OriginalStatus.Text = "👕 Pakaian Awal: " .. count .. " items"
end

