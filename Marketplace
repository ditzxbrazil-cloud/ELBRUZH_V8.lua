    self.OriginalWindow.Visible = false
    self.MinimizedIcon.Visible = true
    
    TweenService:Create(self.MinimizedIcon, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Size = UDim2.new(0, 60, 0, 60)}):Play()
