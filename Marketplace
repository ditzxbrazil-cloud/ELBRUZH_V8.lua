local function createProtectedGUI()
    local gui = Instance.new("ScreenGui")
    gui.Name = "shhhhnayy05_Marketplace"
    gui.ResetOnSpawn = false
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    
    --// Try multiple methods for Delta and other executors
    local success = false
    
    --// Method 1: Delta (using _G or global)
    if not success and _G and typeof(_G) == "table" then
        success = pcall(function()
            -- Delta sometimes uses _G.Delta or just checks for CoreGui access
            gui.Parent = CoreGui
        end)
    end
    
    --// Method 2: Check for Delta specific
    if not success and typeof(getgenv) == "function" then
        local genv = getgenv()
        if genv.Delta or genv.delta then
            success = pcall(function()
                gui.Parent = CoreGui
            end)
        end
    end
    
    --// Method 3: Direct CoreGui (works on most executors including Delta)
    if not success then
        success = pcall(function()
            -- Delta allows CoreGui access directly
            gui.Parent = CoreGui
        end)
    end
    
    --// Method 4: PlayerGui fallback
    if not success then
        pcall(function()
            gui.Parent = LocalPlayer:WaitForChild("PlayerGui")
        end)
    end
    
    return gui
end

